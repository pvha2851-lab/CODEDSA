#include<bits/stdc++.h>
#define ll long long
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n,m;
		cin>>n>>m;
		ll dp[n+5][m+5];
		for(int i=0;i<=n;i++){
			for(int j=0;j<=m;j++){
				dp[i][j]=1;
			}
		}
		for(int i=1;i<=n;i++){
			for(int j=1;j<=m;j++){
				dp[i][j]+=dp[i-1][j]+dp[i][j-1];
			}
		}
		cout<<(dp[n][m]+1)/2<<endl;
	}
	return 0;
}
