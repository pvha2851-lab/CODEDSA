#include<bits/stdc++.h>
using namespace std;
vector<int> adj[1005];
bool visited[1005];
int parent[1005];
void DFS(int u){
	visited[u]=true;
	for(int v:adj[u]){
		if(!visited[v]){
			DFS(v);
			parent[v]=u;
		}
	}
}
void path(int s,int t){
	DFS(s);
	if(!visited[t]){
		cout<<-1<<endl;
	}
	else{
		vector<int> res;
		while(s!=t){
			res.push_back(t);
			t=parent[t];
		}
		res.push_back(s);
		reverse(res.begin(),res.end());
		for(int x:res)	cout<<x<<" ";
	}
}
void nhap(){
	for(int i=1;i<=1005;i++){
		adj[i].clear();
	}
	memset(parent,0,sizeof(parent));
	int n,m,s,t;
	cin>>n>>m>>s>>t;
	for(int i=1;i<=m;i++){
		int x,y;
		cin>>x>>y;
		adj[x].push_back(y);
	}
	path(s,t);
}
int main(){
	int t;
	cin>>t;
	while(t--){
		nhap();
		cout<<endl;
	}
	return 0;
}
