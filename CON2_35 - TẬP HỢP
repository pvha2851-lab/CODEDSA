#include<bits/stdc++.h>
using namespace std;
int n,k,s;
int dem=0;
void Try(int i,int cnt,int sum){
	if(sum==s&&k==cnt){
		dem++;
		return;
	}
	if(sum>s||cnt>k)	return;
	for(int j=i+1;j<=n;j++){
		if(sum+j<=s){
			Try(j,cnt+1,sum+j);
		}
	}
}
int main(){
	while(true){
		cin>>n>>k>>s;
		if(n==0&&k==0&&s==0)	break;
		dem=0;
		Try(0,0,0);
		cout<<dem<<endl;
	}
	return 0;
}
