#include<bits/stdc++.h>
using namespace std;
int n,k,s;
int dem;
void Try(int i,int cnt,int sum){
	if(cnt==k&&sum==s){
		dem++;
		return;
	}
	if(cnt>k||sum>s)	return;
	for(int j=i;j<=n;j++){
		if(sum+j<=s){
			Try(j+1,cnt+1,sum+j);
		}
	}
}
int main(){
	while(1){
		cin>>n>>k>>s;
		if(n==0&&k==0&&s==0)	break;
		dem=0;
		Try(1,0,0);
		cout<<dem<<endl;
	}
	return 0;
}
