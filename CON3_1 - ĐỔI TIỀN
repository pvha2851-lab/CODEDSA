#include<bits/stdc++.h>
#define ll long long
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		ll s;
		cin>>s;
		int res=0;
		int a[]={1,2,5,10, 20, 50, 100, 200, 500, 1000};
		for(int i=9;i>=0;i--){
			if(s>=a[i]){
				ll x=s/a[i];
				res+=x;
				s-=x*a[i];
			}
		}
		cout<<res<<endl;
	}
	return 0;
}
