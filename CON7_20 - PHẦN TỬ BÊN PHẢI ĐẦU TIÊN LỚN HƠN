#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<int> a(n);
		for(int i=0;i<n;i++){
			cin>>a[i];
		}
		for(int i=0;i<n;i++){
			bool check=false;
			for(int j=i+1;j<n&&!check;j++){
				if(a[i]<a[j]){
					cout<<a[j]<<" ";
					check=true;
				}
			}
			if(!check)	cout<<-1<<" ";
		}
		cout<<endl;
	}
	return 0;
}
