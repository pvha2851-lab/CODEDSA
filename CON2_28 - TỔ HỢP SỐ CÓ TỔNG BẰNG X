#include<bits/stdc++.h>
using namespace std;
int n,s;
vector<int> a;
vector<vector<int>> res;
void Try(int i,int sum,vector<int> b){
	if(sum==s){
		res.push_back(b);
		return;
	}
	if(sum>s)	return;
	for(int j=i;j<n;j++){
		if(sum+a[j]<=s){
			b.push_back(a[j]);
			Try(j,sum+a[j],b);
			b.pop_back();
		}
	}
}
int main(){
	int t;
	cin>>t;
	while(t--){
		res.clear();
		a.clear();
		cin>>n>>s;
		vector<int> b;
		for(int i=0;i<n;i++){
			int x;cin>>x;
			a.push_back(x);
		}
		sort(a.begin(),a.end());
		Try(0,0,b);
		if(res.empty())	cout<<-1;
		for(int i=0;i<res.size();i++){
			cout<<"[";
			for(int j=0;j<res[i].size();j++){
				cout<<res[i][j];
				if(j!=res[i].size()-1)	cout<<" ";
			}
			cout<<"]";
		}
		cout<<endl;
	}
	return 0;
}
