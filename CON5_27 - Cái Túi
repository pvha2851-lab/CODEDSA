#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n,W;
		cin>>n>>W;
		vector<int> w(n+5),c(n+5);
		for(int i=1;i<=n;i++){
			cin>>w[i];
		}
		for(int i=1;i<=n;i++){
			cin>>c[i];
		}
		vector<vector<int>> dp(n+5,vector<int>(W+5,0));
		for(int i=1;i<=n;i++){
			for(int j=1;j<=W;j++){
				dp[i][j]=dp[i-1][j];
				if(j>=w[i]){
					dp[i][j]=max(dp[i][j],dp[i-1][j-w[i]]+c[i]);	
				}
			}
		}
		cout<<dp[n][W]<<endl;
	}
	return 0;
}
