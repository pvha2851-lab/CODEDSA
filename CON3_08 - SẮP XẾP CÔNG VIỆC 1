#include<bits/stdc++.h>
using namespace std;
bool cmp(pair<int,int>a,pair<int,int>b){
	return a.second<b.second;
}
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		pair<int,int> p[n];
		for(int i=0;i<n;i++){
			cin>>p[i].first;
		}
		for(int i=0;i<n;i++){
			cin>>p[i].second;
		}
		sort(p,p+n,cmp);
		int res=1;
		int time_end=p[0].second;
		for(int i=1;i<n;i++){
			if(p[i].first>=time_end){
				res++;
				time_end=p[i].second;
			}
		}
		cout<<res<<endl;
	}
	return 0;
}
