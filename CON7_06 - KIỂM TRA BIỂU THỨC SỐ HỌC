#include<bits/stdc++.h>
using namespace std;
bool check(string s){
	stack<char> stk;
	for(char c:s){
		if(c==')'){
			char top=stk.top();stk.pop();
			bool ok=false;
			while(top!='('){
				if(top=='+'||top=='-'||top=='*'||top=='/'){
					ok=true;
				}
				top=stk.top();stk.pop();
			}
			if(!ok){
				return true;
			}
		}
		else{
			stk.push(c);
		}
	}
	return false;
}
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string s;
		getline(cin,s);
		if(check(s)){
			cout<<"Yes\n";
		}
		else{
			cout<<"No\n";
		}
	}
	return 0;
}
