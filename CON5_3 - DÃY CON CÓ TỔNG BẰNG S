#include<bits/stdc++.h>
#define ll long long
using namespace std;
ll n,s;
bool check;
bool Try(int i,ll sum,vector<ll> v){
	if(sum==s)	return true;
	if(sum>s)	return false;
	for(int j=i;j<v.size();j++){
		if(sum+v[j]<=s){
			if(Try(j+1,sum+v[j],v))
				return true;
		}
	}
	return false;
}
int main(){
	int t;
	cin>>t;
	while(t--){
		cin>>n>>s;
		vector<ll> v(n);
		for(int i=0;i<n;i++){
			cin>>v[i];
		}
		sort(v.begin(),v.end());
		if(Try(0,0,v)){
			cout<<"YES\n";
		}
		else{
			cout<<"NO\n";
		}
	}
	return 0;
}
