#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string s;
		getline(cin,s);
		stack<int> stk;
		bool check=true;
		for(int i=s.size()-1;i>=0&&check;i--){
			if(s[i]>='0'&&s[i]<='9'){
				stk.push(s[i]-'0');
			}
			else{
				int a=stk.top();stk.pop();
				int b=stk.top();stk.pop();
				int res=0;
				if(s[i]=='+')	res=a+b;
				else if(s[i]=='-')	res=a-b;
				else if(s[i]=='*')	res=a*b;
				else if(s[i]=='/'){
					if(b==0){//TH a/0=vo nghiem
						check=false;
						cout<<0<<endl;
					}
					else{
						res=a/b;
					}
				}
				stk.push(res);	
			}
		}
		if(check)	cout<<stk.top()<<endl;
	}
	return 0;
}
