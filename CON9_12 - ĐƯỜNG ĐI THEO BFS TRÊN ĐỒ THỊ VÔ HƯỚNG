#include<bits/stdc++.h>
using namespace std;
vector<int> adj[1005];
bool visited[1005];
int parent[1005];
void BFS(int u){
	visited[u]=true;
	queue<int> Q;
	Q.push(u);
	while(!Q.empty()){
		int x=Q.front();Q.pop();
		for(int y:adj[x]){
			if(!visited[y]){
				Q.push(y);
				parent[y]=x;
				visited[y]=true;
			}
		}
	}
}
void path(int s,int t){
	BFS(s);
	if(!visited[t]){
		cout<<-1;
	}
	else{
		vector<int> res;
		while(t!=s){
			res.push_back(t);
			t=parent[t];
		}
		res.push_back(s);
		reverse(res.begin(),res.end());
		for(int x:res){
			cout<<x<<" ";
		}
	}
}
void nhap(){
	for(int i=1;i<1005;i++){
		adj[i].clear();
	}
	memset(parent,0,sizeof(parent));
	int n,m,s,t;
	cin>>n>>m>>s>>t;
	for(int i=1;i<=m;i++){
		int x,y;
		cin>>x>>y;
		adj[x].push_back(y);
		adj[y].push_back(x);
	}
	memset(visited,false,sizeof(visited);
	path(s,t);
}
int main(){
	int t;
	cin>>t;
	while(t--){
		nhap();
		cout<<endl;
	}
	return 0;
}
