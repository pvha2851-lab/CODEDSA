#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string s;
		getline(cin,s);
		stack<int> stk;
		stk.push(-1);
		int res=0;
		for(int i=0;i<s.size();i++){
			if(s[i]=='(')	stk.push(i);
			else{
				stk.pop();
				if(stk.empty())	stk.push(i);
				else			res=max(res,i-stk.top());
			}
		}
		cout<<res<<endl;
	}
	return 0;
}
