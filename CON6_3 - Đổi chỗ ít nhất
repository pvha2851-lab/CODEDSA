#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<int> a(n);
		for(int i=0;i<n;i++)	cin>>a[i];
		int res=0;
		for(int i=0;i<n-1;i++){
			int k=i;
			for(int j=i+1;j<n;j++){
				if(a[k]>a[j]){
					k=j;
				}
			}
			if(k!=i){
				res++;
				swap(a[k],a[i]);
			}
		}
		cout<<res<<endl;
	}
	return 0;
}
