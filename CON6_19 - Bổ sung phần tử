#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;cin>>n;
		vector<int> a(n);
		map<int,int> mp;
		for(int i=0;i<n;i++){
			cin>>a[i];
			mp[a[i]]++;
		}
		sort(a.begin(),a.end());
		int begin=a[0],end=a[a.size()-1];
		int res=0;
		for(int i=begin;i<=end;i++){
			if(mp[i]==0)	res++;
		}
		cout<<res<<endl;
	}
	return 0;
}
