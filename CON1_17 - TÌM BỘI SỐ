#include<bits/stdc++.h>
#define ll long long
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		ll N;
		cin>>N;
		queue<ll> Q;
		Q.push(9);
		while(!Q.empty()){
			ll x=Q.front();Q.pop();
			if(x%N==0){
				cout<<x<<endl;
				break;
			}
			Q.push(x*10);
			Q.push(x*10+9);
		}
	}
	return 0;
}
