#include<bits/stdc++.h>
using namespace std;
int search(int l,int r,int a[],int x){
	int res=-1;
	while(l<=r){
		int mid=(l+r)/2;
		if(a[mid]<=x){
			res=mid;
			l=mid+1;
		}
		else if(a[mid]>x){
			r=mid-1;
		}
	}
	return res;
}	
int main(){
	int t;
	cin>>t;
	while(t--){
		int n,x;
		cin>>n>>x;
		int a[n+5];
		for(int i=1;i<=n;i++){
			cin>>a[i];
		}
		sort(a+1,a+n+1);
		cout<<search(1,n,a,x)<<endl;
	}
	return 0;
}
