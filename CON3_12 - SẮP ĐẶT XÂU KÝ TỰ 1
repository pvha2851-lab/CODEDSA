#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string s;
		cin>>s;
		int a[30]={0};
		for(char c:s){
			a[c-'a']++;
		}
		int cnt_max=0;
		for(int i=0;i<30;i++){
			cnt_max=max(cnt_max,a[i]);
		}
		if(cnt_max*2>s.size()+1){
			cout<<-1<<endl;
		}
		else{
			cout<<1<<endl;
		}
	}
	return 0;
}
