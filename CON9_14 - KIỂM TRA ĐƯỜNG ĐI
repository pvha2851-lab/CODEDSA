#include<bits/stdc++.h>
using namespace std;
vector<int> adj[1005];
bool visited[1005];
void DFS(int u){
	visited[u]=true;
	for(int v:adj[u]){
		if(!visited[v]){
			DFS(v);
		}
	}
}
void nhap(){
	for(int i=1;i<1005;i++){
		adj[i].clear();
	}
	memset(visited,false,sizeof(visited));
	int n,m;
	cin>>n>>m;
	for(int i=1;i<=m;i++){
		int x,y;
		cin>>x>>y;
		adj[x].push_back(y);
		adj[y].push_back(x);
	}
}
int main(){
	int t;
	cin>>t;
	while(t--){
		nhap();
		int Q;
		cin>>Q;
		while(Q--){
			int s,t;
			cin>>s>>t;
			memset(visited,false,sizeof(visited));
			DFS(s);
			if(visited[t]){
				cout<<"YES\n";
			}
			else{
				cout<<"NO\n";
			}
		}
	}
	return 0;
}
