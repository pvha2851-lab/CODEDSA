#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		deque<int> Q;
		int x;
		while(n--){
			cin>>x;
			if(x==1){
				cout<<Q.size()<<endl;
			}
			else if(x==2){
				if(Q.empty()){
					cout<<"YES\n";
				}
				else{
					cout<<"NO\n";
				}
			}
			else if(x==3){
				int tmp;
				cin>>tmp;
				Q.push_back(tmp);
			}
			else if(x==4){
				if(!Q.empty()){
					Q.pop_front();
				}
			}
			else if(x==5){
				if(Q.empty()){
					cout<<"-1\n";
				}
				else{
					cout<<Q.front()<<endl;
				}
			}
			else{
				if(Q.empty()){
					cout<<"-1\n";
				}
				else{
					cout<<Q.back()<<endl;
				}
			}
		}
	}
	return 0;
}
