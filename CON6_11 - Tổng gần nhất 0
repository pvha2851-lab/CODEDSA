#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		int a[n];
		int d=INT_MAX;
		int res=INT_MAX;
		for(int i=0;i<n;i++)	cin>>a[i];
		for(int i=0;i<n;i++){
			for(int j=i+1;j<n;j++){
				if(d>abs(a[i]+a[j])){
					d=abs(a[i]+a[j]);
					res=a[i]+a[j];
				}
			}
		}
		cout<<res<<endl;
	}
	return 0;
}
