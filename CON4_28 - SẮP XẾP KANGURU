#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int N;
		cin>>N;
		vector<int> a(N);
		for(int i=0;i<N;i++){
			cin>>a[i];
		}
		sort(a.begin(),a.end());
		int cnt=0;
		int i=N/2-1;//cuoi nua be
		int j=N-1;//cuoi nua lon
		while(i>=0&&j>=N/2){
			if(a[j]>=2*a[i]){
				cnt++;
				i--;
				j--;
			}
			else{
				i--;//con be cao qua ,tim con thap hon
			}
		}
		//tong so con nhin thay=tong so con-tong so con ghep cap
		cout<<N-cnt<<endl;
	}
	return 0;
}
