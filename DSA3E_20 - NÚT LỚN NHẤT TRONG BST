#include<bits/stdc++.h>
using namespace std;
struct node{
	int data;
	node *left;
	node *right;
};
node* makeNode(int x){
	node *newNode=new node;
	newNode->data=x;
	newNode->left=NULL;
	newNode->right=NULL;
    return newNode;
}
node* insert(node *root,int key){
	if(root==NULL)	return makeNode(key);
	if(key<root->data) root->left=insert(root->left,key);
	else if(key>root->data)	root->right=insert(root->right,key);
	return root;
}
int findMax(node *root){
	while(root->right!=NULL){
		root=root->right;
	}
	return root->data;
}
int main(){
	node *root=NULL;
	int N;
	cin>>N;
	vector<int> A(N);
	for(int i=0;i<N;i++){
		cin>>A[i];
	}
	for(int i=0;i<N;i++){
		root=insert(root,A[i]);
	}
	cout<<findMax(root)<<endl;
	return 0;
}
