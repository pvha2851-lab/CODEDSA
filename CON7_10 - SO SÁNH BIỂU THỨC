#include<bits/stdc++.h>
using namespace std;
string tuongduong(string s){
	stack<int> stk;
	stk.push(1);//dau +
	int sign=1;
	string res="";
	for(char c:s){
		if(c=='+')	sign=1;
		else if(c=='-')	sign=-1;
		else if(c=='('){
			stk.push(stk.top()*sign);
			sign=1;
		}
		else if(c==')')	stk.pop();
		else{
			int cursign=stk.top()*sign;
			if(cursign==1)	res+='+';
			else res+='-';
			res+=c;
			sign=1;
		}
	}
	return res;
}
int main(){
	int t;cin>>t;
	cin.ignore();
	while(t--){
		string s1,s2;
		getline(cin,s1);
		getline(cin,s2);
		if(tuongduong(s1)==tuongduong(s2))	cout<<"YES\n";
		else cout<<"NO\n";
	}
	return 0;
}
