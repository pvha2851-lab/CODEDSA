#include <bits/stdc++.h>
using namespace std;
int n,m;
vector<int> adj[1005];
bool visited[1005];
int parent[1005];
void DFS(int u,int &check){
	visited[u]=true;
	for(int v:adj[u]){
		if(!visited[v]){
			DFS(v,check);
			parent[v]=u;
		}
		else if(parent[u]!=v)	check=1;
	}
}
void nhap(){
	cin>>n>>m;
	for(int i=1;i<1005;i++)	adj[i].clear();
	memset(visited,false,sizeof(visited));
    memset(parent,0,sizeof(parent));
	for(int i=1;i<=m;i++){
		int x,y;cin>>x>>y;
		adj[x].push_back(y);
		adj[y].push_back(x);
	}
	int check=0;
	DFS(1,check);
	if(check==1)	cout<<"YES\n";
	else	cout<<"NO\n";
}
int main(){
	int t;
	cin>>t;
	while(t--){
		nhap();
	}
	return 0;
}
