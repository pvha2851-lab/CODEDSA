#include<bits/stdc++.h>
#define ll long long
using namespace std;
int n;
ll s,a[35];
int cost_min;
void Try(int i,ll sum,int cnt){
	if(sum==s){
		cost_min=min(cost_min,cnt);
		return;
	}
	if(i==n||cnt>=cost_min)	return;
	for(int j=i;j<n;j++){
		if(sum+a[j]<=s){
			Try(j+1,sum+a[j],cnt+1);
		}
	}
}
int main(){
	int t;
	cin>>t;
	while(t--){
		cin>>n>>s;
		for(int i=0;i<n;i++){
			cin>>a[i];
		}
		sort(a,a+n,greater<ll>());
		cost_min=INT_MAX;
		Try(0,0,0);
		if(cost_min==INT_MAX)	cout<<-1<<endl;
		else cout<<cost_min<<endl;
	}
	return 0;
}
