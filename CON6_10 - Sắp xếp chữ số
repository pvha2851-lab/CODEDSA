#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		cin.ignore();
		vector<string> a;
		for(int i=0;i<n;i++){
			string s;
			cin>>s;
			a.push_back(s);
		}
		map<char,int> cnt;
		for(int i=0;i<a.size();i++){
			for(int j=0;j<a[i].size();j++){
				cnt[a[i][j]]++;
			}
		}
		for(auto x:cnt){
			cout<<x.first<<" ";
		}
		cout<<endl;
	}
	return 0;
}
