#include<bits/stdc++.h>
using namespace std;
map<int,int> dp;
int f(int n){
    if(n == 1) return 0;
    if(dp[n]) return dp[n];
    int res=1+f(n-1);
    for(int i=2;i*i<=n;i++){
        if(n%i==0){
            res=min(res,1+f(max(i,n/i)));
        }
    }
    return dp[n]=res;
}
int main(){
    int t; cin>>t;
    while(t--){
        int n;cin>>n;
        cout<<f(n)<<endl;
    }
}
