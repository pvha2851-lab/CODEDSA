#include<bits/stdc++.h>
#define ll long long
using namespace std;
ll mod=1e9+7;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<ll> a(n);
		for(int i=0;i<n;i++)	cin>>a[i];
		ll sum=0;
		sort(a.begin(),a.end());
		for(int i=0;i<n;i++){
			sum=(sum+i*a[i])%mod;
		}
		cout<<sum<<endl;
	}
	return 0;
}
