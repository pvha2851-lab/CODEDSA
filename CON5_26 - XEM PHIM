#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int C,n;
		cin>>C>>n;
		vector<int> w(n);
		for(int i=1;i<=n;i++){
			cin>>w[i];
		}
		vector<vector<int>> dp(n+5,vector<int>(C+5));
		for(int i=1;i<=n;i++){
			for(int j=1;j<=C;j++){
				dp[i][j]=dp[i-1][j];
				if(j>=w[i])	dp[i][j]=max(dp[i][j],dp[i-1][j-w[i]]+w[i]);
			}
		}
		cout<<dp[n][C]<<endl;
	}
	return 0;
}
