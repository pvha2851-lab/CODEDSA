#include<bits/stdc++.h>
using namespace std;
int n;
vector<vector<int>> res;
void Try(int i,int sum,vector<int> a){
	if(sum==0){
		res.push_back(a);
		return;
	}
	for(int j=i;j>=1;j--){
		if(sum-j>=0){
			a.push_back(j);
			Try(j,sum-j,a);
			a.pop_back();	
		}
	}
}
int main(){
	int t;
	cin>>t;
	while(t--){
		cin>>n;
		res.clear();
		vector<int> a;
		Try(n,n,a);
		for(int i=0;i<res.size();i++){
			sort(res[i].begin(),res[i].end());
			cout<<"(";
			for(int j=res[i].size()-1;j>=0;j--){
				cout<<res[i][j];
				if(j!=0)	cout<<" ";
			}
			cout<<") ";
		}
		cout<<endl;
	}
	return 0;
}
