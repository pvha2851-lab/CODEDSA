#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int V,E;
		cin>>V>>E;
		vector<int> in(V+1,0),out(V+1,0);
		for(int i=1;i<=E;i++){
			int u,v;
			cin>>u>>v;
			out[u]++;
			in[v]++;
		}
		bool ok=true;
		for(int i=1;i<=V;i++){
			if(in[i]!=out[i]){
				ok=false;
				break;
			}
		}
		if(ok)	cout<<1<<endl;
		else	cout<<0<<endl;
	}
	return 0;
}
