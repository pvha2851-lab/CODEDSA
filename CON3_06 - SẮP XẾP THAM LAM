#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<int> a(n),b(n);
		for(int i=0;i<n;i++){
			cin>>a[i];
		}
		b=a;
		sort(b.begin(),b.end());
		bool ok=true;
		for(int i=0;i<=n/2;i++){
			int j=n-i-1;
			if(a[i]==b[i]||a[j]==b[i]) continue;
			else{
				ok=false;
				break;
			}
		}
		if(ok)	cout<<"Yes\n";
		else cout<<"No\n";
	}
	return 0;
}
