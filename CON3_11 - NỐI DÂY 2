#include<bits/stdc++.h>
#define ll long long
using namespace std;
const ll mod=1e9+7;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;cin>>n;
		priority_queue<ll,vector<ll>,greater<ll>>Q;
		for(int i=0;i<n;i++){
			int x;
			cin>>x;
			Q.push(x);
		}
		ll ans=0;
		while(Q.size()!=1){
			ll top1=Q.top();Q.pop();
			ll top2=Q.top();Q.pop();
			ans+=top1+top2;
			ans%=mod;
			Q.push(top1+top2);
		}
		cout<<ans<<endl;
	}
	return 0;
}
