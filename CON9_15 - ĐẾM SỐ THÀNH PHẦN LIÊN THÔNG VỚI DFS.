#include<bits/stdc++.h>
using namespace std;
vector<int> adj[1005];
bool visited[1005];
void DFS(int u){
	visited[u]=true;
	for(int v:adj[u]){
		if(!visited[v]){
			DFS(v);
		}
	}
}
int tplt(int n){
	int cnt=0;
	for(int i=1;i<=n;i++){
		if(!visited[i]){
			cnt++;
			DFS(i);
		}
	}
	return cnt;
}
void nhap(){
	for(int i=0;i<1005;i++){
		adj[i].clear();
	}
	int n,m;
	cin>>n>>m;
	for(int i=0;i<m;i++){
		int x,y;
		cin>>x>>y;
		adj[x].push_back(y);
		adj[y].push_back(x);
	}
	memset(visited,false,sizeof(visited));
	cout<<tplt(n)<<endl;
}
int main(){
	int t;
	cin>>t;
	while(t--){
		nhap();
	}
	return 0;
}
