#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<int> a(n);
		for(int i=0;i<n;i++){
			cin>>a[i];
		}
		for(int i=0;i<n;i++){
			bool check=false;
			for(int j=i+1;j<n;j++){
				if(a[i]<a[j]){
					for(int k=j+1;k<n&&!check;k++){
						if(a[j]>a[k]){
							cout<<a[k]<<" ";
							check=true;
						}
					}
					break;
				}
			}
			if(!check)	cout<<-1<<" ";
		}
		cout<<endl;
	}
	return 0;
}
