#include<bits/stdc++.h>
#define ll long long
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		ll n;
		cin>>n;
		queue<int> Q;
		Q.push(1);
		while(!Q.empty()){
			ll x=Q.front();Q.pop();
			if(x%n==0){
				cout<<x<<endl;
				break;
			}
			Q.push(x*10);
			Q.push(x*10+1);
		}		
	}
	return 0;
}
