#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string A,B;
		int K;
		cin>>K>>A>>B;
		while(A.size()<B.size()) A="0"+A;
		while(B.size()<A.size()) B="0"+B;
		int carry=0;
		string res="";
		for(int i=A.size()-1;i>=0;i--){
			int sum=(A[i]-'0')+(B[i]-'0')+carry;
			res.push_back(sum%K+'0');
			carry=sum/K;
		}
		if(carry>0){
			res.push_back(carry+'0');
		}
		reverse(res.begin(),res.end());
		cout<<res<<endl;
	}
	return 0;
}
