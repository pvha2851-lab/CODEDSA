#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<int> a(n);
		vector<int> dp(n,1);
		for(int &x:a)	cin>>x;
		for(int i=1;i<n;i++){
			for(int j=0;j<i;j++){
				if(a[i]>a[j]&&dp[i]<dp[j]+1){
					dp[i]=dp[j]+1;
				}
			}
		}
		cout<<*max_element(dp.begin(),dp.end())<<endl;
	}
	return 0;
}
