#include<bits/stdc++.h>
using namespace std;
string minstring(string s){
	for(char &c:s){
		if(c=='6')	c='5';
	}
	return s;
}
string maxstring(string s){
	for(char &c:s){
		if(c=='5')	c='6';
	}
	return s;
}
string sumstring(string s1,string s2){
	while(s1.size()<s2.size())	s1="0"+s1;
	while(s1.size()>s2.size())	s2="0"+s2;
	int carry=0;
	string res="";
	for(int i=s1.size()-1;i>=0;i--){
		int sum=(s1[i]-'0')+(s2[i]-'0')+carry;
		res.push_back(sum%10+'0');
		carry=sum/10;	
	}
	if(carry>0)	res=res+"1";
	reverse(res.begin(),res.end());
	return res;
}
int main(){
	string a,b;
	cin>>a>>b;
	a=minstring(a);
	b=minstring(b);
	cout<<sumstring(a,b)<<" ";
	a=maxstring(a);
	b=maxstring(b);
	cout<<sumstring(a,b);
	return 0;
}
