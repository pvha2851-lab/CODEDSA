#include<bits/stdc++.h>
#define ll long long
using namespace std;
ll n,p,s;
vector<ll> isprime(201,1);
vector<ll> prime;
vector<vector<ll>> res;
void sangnt(){
	for(int i=2;i*i<=200;i++){
		if(isprime[i]){
			for(int j=i*i;j<=200;j+=i){
				isprime[j]=0;
			}
		}
	}
	for(int i=2;i<=200;i++){
		if(isprime[i]){
			prime.push_back(i);
		}
	}
}
void Try(int i,int k,ll sum,vector<ll> v){
	if(k==n&&sum==s){
		res.push_back(v);
		return;
	}
	if(k>n||sum>s)	return;
	for(int j=i;j<prime.size();j++){
		if(prime[j]+sum<=s&&k<n){
			v.push_back(prime[j]);
			Try(j+1,k+1,prime[j]+sum,v);
			v.pop_back();
		}
	}
}
int main(){
	sangnt();
	int t;
	cin>>t;
	while(t--){
		res.clear();
		vector<ll> v;
		cin>>n>>p>>s;
		int pos=upper_bound(prime.begin(),prime.end(),p)-prime.begin();
		Try(pos,0,0,v);
		cout<<res.size()<<endl;
		for(int i=0;i<res.size();i++){
			for(int j=0;j<res[i].size();j++){
				cout<<res[i][j]<<" ";
			}
			cout<<endl;
		}
	}
	return 0;
}
