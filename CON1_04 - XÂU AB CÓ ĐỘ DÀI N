#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		string s=string(n,'A');
		bool final=false;
		while(!final){
			cout<<s<<" ";
			int i=n-1;
			while(i>=0&&s[i]=='B')	i--;
			if(i<0){
				final=true;//ket thuc ctrinh
			}
			s[i]='B';//bat dau thay doi tu vi tri nay
			for(int j=i+1;j<n;j++)	s[j]='A';//reset o phi sau
		}
		cout<<endl;
	}
	return 0;
}
