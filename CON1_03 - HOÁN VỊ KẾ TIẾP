#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		int a[n+5];
		for(int i=1;i<=n;i++){
			cin>>a[i];
		}
		int i=n-1;
		while(i>=1&&a[i]>a[i+1])	i--;
		if(i==0){
			// la hoan vi cuoi cung->quay lai dau tien
			for(int j=1;j<=n;j++)	cout<<j<<" ";
		}
		else{
			int j=n;
			while(a[i]>a[j])	j--;
			swap(a[i],a[j]);
			reverse(a+i+1,a+n+1);
			for(int j=1;j<=n;j++)	cout<<a[j]<<" ";
		}
		cout<<endl;
	}
	return 0;
}
