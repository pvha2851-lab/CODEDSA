#include<bits/stdc++.h>
#define ll long long
using namespace std;
ll F[95];
ll n,k;
void sangnt(){
	F[1]=F[2]=1;
	for(ll i=3;i<=92;i++){
		F[i]=F[i-1]+F[i-2];
	}
}
char solve(ll n,ll k){
	if(n==1)	return 'A';
	if(n==2)	return 'B';
	if(k<=F[n-2]){
		solve(n-2,k);
	}
	else{
		solve(n-1,k-F[n-2]);
	}
}
int main(){
	sangnt();
	int t;
	cin>>t;
	while(t--){
		cin>>n>>k;
		cout<<solve(n,k)<<endl;
	}
	return 0;
}
