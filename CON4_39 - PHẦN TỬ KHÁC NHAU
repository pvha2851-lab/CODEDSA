#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		int a[n],b[n-1];
		for(int i=0;i<n;i++)	cin>>a[i];
		for(int i=0;i<n-1;i++)	cin>>b[i];
		int l=0,r=n-2;//b chi co n-1 phan tu
		int res=n-1;//thieu o cuoi
		while(l<=r){
			int mid=(l+r)/2;
			if(a[mid]==b[mid]){
				l=mid+1;
			}
			else{
				res=mid;
				r=mid-1;
			}
		}
		cout<<res+1<<endl;
	}
	return 0;
}
