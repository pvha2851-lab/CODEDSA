#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		vector<pair<int,int>> a;
		for(int i=0;i<n;i++){
			int x,y;
			cin>>x>>y;
			a.push_back({x,y});
		}
		double dmin=INT_MAX;
		for(int i=0;i<n;i++){
			int x1=a[i].first;
			int y1=a[i].second;
			for(int j=i+1;j<n;j++){
				int x2=a[j].first;
				int y2=a[j].second;
				double d=sqrt((x1-x2)*(x1-x2)*1.0+(y1-y2)*(y1-y2)*1.0)*1.0;
				dmin=min(dmin,d);
			}
		}
		cout<<fixed<<setprecision(6)<<dmin<<endl;
	}
	return 0;
}
