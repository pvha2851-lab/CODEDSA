#include<bits/stdc++.h>
using namespace std;
vector<int> adj[1005];
bool visited[1005];
void BFS(int u){
	queue<int> Q;
	Q.push(u);
	visited[u]=true;
	while(!Q.empty()){
		int x=Q.front();Q.pop();
		cout<<x<<" ";
		for(int y:adj[x]){
			if(!visited[y]){
				visited[y]=true;
				Q.push(y);
			}
		}
	}
}
void nhap(){
	for(int i=1;i<1005;i++){
		adj[i].clear();
	}
	int n,m,s;
	cin>>n>>m>>s;
	for(int i=1;i<=m;i++){
		int x,y;
		cin>>x>>y;
		adj[x].push_back(y);
	}
	memset(visited,false,sizeof(visited));
	BFS(s);
}
int main(){
	int t;
	cin>>t;
	while(t--){
		nhap();
		cout<<endl;
	}
	return 0;
}
