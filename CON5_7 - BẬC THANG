#include<bits/stdc++.h>
#define ll long long
using namespace std;
const ll mod=1e9+7;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n,k;
		cin>>n>>k;
		vector<ll> dp(n+5,0);
		dp[0]=1;
		for(int i=1;i<=n;i++){
			for(int j=1;j<=min(i,k);j++){
				dp[i]+=dp[i-j];
				dp[i]%=mod;
			}
		}
		cout<<dp[n]<<endl;
	}
	return 0;
}
