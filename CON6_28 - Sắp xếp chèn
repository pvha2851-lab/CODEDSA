#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		int a[n];
		vector<int> res;
		vector<vector<int>> ans;
		for(int i=0;i<n;i++){
			cin>>a[i];
		}
		for(int i=0;i<n;i++){
			int key=a[i];
			int j=i-1;
			while(j>=0&&a[j]>key){
				a[j+1]=a[j];
				j--;
			}
			a[j+1]=key;
			res.clear();
			for(int k=0;k<=i;k++){
				res.push_back(a[k]);
			}
			ans.push_back(res);
		}
		for(int i=ans.size()-1;i>=0;i--){
			cout<<"Buoc "<<i<<": ";
			for(int j=0;j<ans[i].size();j++){
				cout<<ans[i][j]<<" ";
			}
			cout<<endl;
		}
	}
	return 0;
}
