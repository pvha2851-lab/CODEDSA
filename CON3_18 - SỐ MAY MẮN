#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	//4x+7y=n
	while(t--){
		int n;
		cin>>n;
		int so4=0,so7=0;
		for(int i=n/7;i>=0;i--){
			if((n-7*i)%4==0){
				so4=(n-7*i)/4;
				so7=i;
                break;
			}
		}
		if(so4==0&&so7==0){
			cout<<-1;
		}
		else{
			for(int i=0;i<so4;i++)	cout<<4;
			for(int i=0;i<so7;i++)	cout<<7;
		}
		cout<<endl;
	}
	return 0;
}
