#include<bits/stdc++.h>
using namespace std;
vector<int> adj[1005];
bool visited[1005];
void DFS(int u){
	cout<<u<<" ";
	visited[u]=true;
	for(int v:adj[u]){
		if(!visited[v]){
			DFS(v);
		}
	}
}
void nhap(){
	for(int i=1;i<1005;i++){
		adj[i].clear();
	}
	int n,m,s;
	cin>>n>>m>>s;
	for(int i=1;i<=m;i++){
		int x,y;
		cin>>x>>y;
		adj[x].push_back(y);
	}
	memset(visited,false,sizeof(visited));
	DFS(s);
}
int main(){
	int t;
	cin>>t;
	while(t--){
		nhap();
		cout<<endl;
	}
	return 0;
}
