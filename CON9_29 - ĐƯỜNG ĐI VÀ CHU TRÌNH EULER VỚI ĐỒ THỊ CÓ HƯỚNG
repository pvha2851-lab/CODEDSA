#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int V,E;
		cin>>V>>E;
		vector<int> deg(V+1,0);
		for(int i=1;i<=E;i++){
			int u,v;
			cin>>u>>v;
			deg[u]++;
			deg[v]++;
		}
		int cnt=0;
		for(int i=1;i<=V;i++){
			if(deg[i]%2==1)	cnt++;
		}
		if(cnt==2){//duong di euler
			cout<<1<<endl;
		}
		else if(cnt==0){//chu trinh euler
			cout<<2<<endl;
		}
		else{
			cout<<0<<endl;
		}
	}
	return 0;
}

