#include<bits/stdc++.h>
using namespace std;
int n;
int c[20][20];
int cost;
bool visited[20];
void Try(int i,int sum,int k){
	if(k==n-1){
		cost=min(cost,sum+c[i][1]);
		return;
	}
	if(sum>=cost||k>=n)	return;
	for(int j=1;j<=n;j++){
		if(!visited[j]&&c[i][j]!=0){
			visited[j]=true;
			Try(j,sum+c[i][j],k+1);
			visited[j]=false;
		}
	}
}
int main(){
	cin>>n;
	for(int i=1;i<=n;i++){
		for(int j=1;j<=n;j++){
			cin>>c[i][j];
		}
	}
	cost=INT_MAX;
	visited[1]=true;
	Try(1,0,0);
	cout<<cost;
	return 0;
}
