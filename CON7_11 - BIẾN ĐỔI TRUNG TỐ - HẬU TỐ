#include<bits/stdc++.h>
using namespace std;
int uutien(char c){
	if(c=='+'||c=='-')	return 1;
	if(c=='*'||c=='/')	return 2;
	return 0;
}
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string s;
		getline(cin,s);
		stack<char> stk;
		string res="";
		for(char c:s){
			if(c>='A'&&c<='Z'||c>='a'&&c<='z'){//toan hang
				res+=c;
			}
			else if(c=='('){
				stk.push(c);
			}
			else if(c==')'){
				while(!stk.empty()&&stk.top()!='('){
					res+=stk.top();	stk.pop();
				}
				if(!stk.empty())	stk.pop();//xoa dau ngoac '('
			}
			else{//toan tu
				while(!stk.empty()&&uutien(stk.top())>=uutien(c)){
					res+=stk.top();	stk.pop();
				}
				stk.push(c);
			}
		}
		while(!stk.empty()){
			res+=stk.top();	stk.pop();
		}
		cout<<res<<endl;
	}
	return 0;
}
