#include<bits/stdc++.h>
#define ll long long
using namespace std;
int main(){
	int n;
	cin>>n;
	cin.ignore();
	vector<int> adj[1005];
	for(int i=1;i<=n;i++){
		string s;
		getline(cin,s);
		stringstream ss(s);
		int x;
		while(ss>>x){
			if(i<x){
				adj[i].push_back(x);
			}
		}
	}
	for(int i=1;i<=n;i++){
		for(int x:adj[i]){
			cout<<i<<" "<<x<<endl;
		}
	}
	return 0;
}
