#include<bits/stdc++.h>
using namespace std;
int n,m;
int cnt;
void Try(int i,int j){
	if(i==n-1&&j==m-1){
		cnt++;
		return;
	}
	if(i+1>=0&&i+1<=n-1)	Try(i+1,j);
	if(j+1>=0&&j+1<=m-1)	Try(i,j+1);
}
int main(){
	int t;
	cin>>t;
	while(t--){
		cin>>n>>m;
		int a[n][m];
		for(int i=0;i<n;i++){
			for(int j=0;j<m;j++)	cin>>a[i][j];
		}
		cnt=0;
		Try(0,0);
		cout<<cnt<<endl;
	}
	return 0;
}
