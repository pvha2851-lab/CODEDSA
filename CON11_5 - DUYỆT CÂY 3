#include<bits/stdc++.h>
using namespace std;
struct node{
	int data;
	node *left;
	node *right;
};
node* makeNode(int x){
	node *newNode=new node;
	newNode->data=x;
	newNode->left=NULL;
	newNode->right=NULL;
	return newNode;
}
node* findNode(node *root,int x){
	if(root==NULL)	return NULL;
	if(root->data==x)	return root;
	node *left=findNode(root->left,x);
	if(left!=NULL)	return left;
	return findNode(root->right,x);
}
void levelOrder(node *root){
	queue<node*> Q;
	Q.push(root);
	cout<<root->data<<" ";
	while(!Q.empty()){
		node *tmp=Q.front();Q.pop();
		if(tmp->left!=NULL){
			Q.push(tmp->left);
			cout<<tmp->left->data<<" ";
		}
		if(tmp->right!=NULL){
			Q.push(tmp->right);
			cout<<tmp->right->data<<" ";
		}
	}
}
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		node *root=NULL;
		set<int> parent,child;
		int n;cin>>n;
		for(int i=0;i<n;i++){
			int x,y;
			char z;
			cin>>x>>y>>z;
			parent.insert(x);
			child.insert(y);
			if(root==NULL)	root=makeNode(x);
			node *cha=findNode(root,x);
			if(cha==NULL)	cha=makeNode(x);
			node *con=makeNode(y);
			if(z=='L') cha->left=con;
			else	cha->right=con;
		}
		int rootVal;
		for(int x:parent){
			if(child.count(x)==0){
				rootVal=x;
				break;
			}
		}
		root=findNode(root,rootVal);
		levelOrder(root);
		cout<<endl;
	}
	return 0;
}
