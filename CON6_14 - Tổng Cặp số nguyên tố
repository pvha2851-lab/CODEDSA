#include<bits/stdc++.h>
using namespace std;
const int N=1e6;
vector<int> prime;
bool isprime[N];
void sangnt(){
	for(int i=2;i*i<=N;i++){
		if(!isprime[i]){
			for(int j=i*i;j<N;j+=i){
				isprime[j]=true;
			}
		}
	}
	for(int i=2;i<=N;i++){
		if(!isprime[i]){
			prime.push_back(i);
		}
	}
}
int main(){
	sangnt();
	int t;
	cin>>t;
	while(t--){
		int n;
		cin>>n;
		for(int x:prime){
			if(x>=n){
				cout<<-1<<endl;
				break;
			}
			int y=n-x;
			if(!isprime[y]){
				cout<<x<<" "<<y<<endl;
				break;
			}
		}
	}
	return 0;
}
