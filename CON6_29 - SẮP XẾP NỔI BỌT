#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	while(t--){
		int b=1;
		int n;
		cin>>n;
		vector<int> a(n);
		for(int i=0;i<n;i++){
			cin>>a[i];
		}
		for(int i=0;i<n-1;i++){
			bool check=false;
			for(int j=0;j<n-i-1;j++){
				if(a[j]>a[j+1]){
					swap(a[j],a[j+1]);
					check=true;
				}
			}
			if(!check)	break;
			cout<<"Buoc "<<b<<": ";
			for(int i=0;i<n;i++){
				cout<<a[i]<<" ";
			}
			b++;
			cout<<endl;
		}
	}
	return 0;
}
