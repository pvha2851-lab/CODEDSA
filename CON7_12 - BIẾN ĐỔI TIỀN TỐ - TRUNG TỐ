#include<bits/stdc++.h>
using namespace std;
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string s;
		getline(cin,s);
		stack<string> stk;
		for(int i=s.size()-1;i>=0;i--){
			if(s[i]=='+'||s[i]=='-'||s[i]=='*'||s[i]=='/'){
				string tmp1=stk.top();stk.pop();
				string tmp2=stk.top();stk.pop();
				string tmp='('+tmp1+s[i]+tmp2+')';
				stk.push(tmp);
			}
			else{
				stk.push(string(1,s[i]));
			}
		}
		cout<<stk.top()<<endl;
	}
	return 0;
}
