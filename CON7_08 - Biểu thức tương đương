#include<bits/stdc++.h>
using namespace std;
string tuongduong(string s){
	string res="";
	stack<int> stk;
	stk.push(1);
	int sign=1;
	for(char c:s){
		if(c=='+')	sign=1;
		else if(c=='-')	sign=-1;
		else if(c==')')	stk.pop();
		else if(c=='('){
			stk.push(stk.top()*sign);
			sign=1;
		}
		else{
			int cursign=stk.top()*sign;
			if(cursign==1)	res+='+';
			if(cursign==-1)	res+='-';
			res+=c;
			sign=1;
		}
	}
	if(res[0]=='+')	res.erase(0,1);
	return res;
}
int main(){
	int t;
	cin>>t;
	cin.ignore();
	while(t--){
		string s;
		getline(cin,s);
		cout<<tuongduong(s)<<endl;
	}
	return 0;
}
